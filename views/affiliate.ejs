<%- include('layout', { body: `
<div id="product-stats" class="product-stats">
  <div class="stat-card-product">
    <div class="stat-icon">🛍️</div>
    <div class="stat-info">
      <div class="stat-value" id="stat-products">0</div>
      <div class="stat-label">Total Produk</div>
    </div>
  </div>
  <div class="stat-card-product stat-success">
    <div class="stat-icon">📝</div>
    <div class="stat-info">
      <div class="stat-value" id="stat-variations">0</div>
      <div class="stat-label">Variasi Konten</div>
    </div>
  </div>
  <div class="stat-card-product stat-info">
    <div class="stat-icon">👥</div>
    <div class="stat-info">
      <div class="stat-value" id="stat-accounts">0</div>
      <div class="stat-label">Akun Aktif</div>
    </div>
  </div>
</div>

<div class="card" style="margin-bottom: 24px;">
  <div class="card-header">
    <h3>➕ Tambah Produk Baru</h3>
  </div>
  <div class="card-body">
    <form action="/product/product/add" method="POST">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px;">
        <div>
          <label style="display: block; margin-bottom: 8px; font-weight: 500; font-size: 14px; color: var(--text-primary);">Nama Produk</label>
          <input type="text" name="product_name" placeholder="Contoh: Headphone Bluetooth XYZ" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-tertiary); color: var(--text-primary); font-size: 14px;">
          <small style="display: block; margin-top: 6px; color: rgba(152, 152, 176, 0.6); font-size: 12px;">Nama produk yang akan dipromosikan</small>
        </div>
        <div>
          <label style="display: block; margin-bottom: 8px; font-weight: 500; font-size: 14px; color: var(--text-primary);">Link Affiliate</label>
          <input type="url" name="affiliate_link" placeholder="https://..." required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-tertiary); color: var(--text-primary); font-size: 14px;">
          <small style="display: block; margin-top: 6px; color: rgba(152, 152, 176, 0.6); font-size: 12px;">Link affiliate dari Shopee/Tokopedia</small>
        </div>
      </div>
      <div style="margin-bottom: 24px;">
        <label style="display: block; margin-bottom: 8px; font-weight: 500; font-size: 14px; color: var(--text-primary);">Deskripsi Produk</label>
        <textarea name="description" rows="3" placeholder="Jelaskan benefit dan keunggulan produk..." required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-tertiary); color: var(--text-primary); font-size: 14px; resize: vertical;"></textarea>
        <small style="display: block; margin-top: 6px; color: rgba(152, 152, 176, 0.6); font-size: 12px;">Jelaskan benefit dan keunggulan produk secara detail</small>
      </div>
      <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px;">➕ Tambah Produk</button>
    </form>
  </div>
</div>

<div class="card" style="margin-bottom: 24px;">
  <div class="card-header">
    <h3>📦 Daftar Produk (<span id="product-count">0</span>)</h3>
  </div>
  <div class="card-body">
    <div id="products-container">
      <div class="loading-state">⏳ Loading...</div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3>📅 Konten Terjadwal (<span id="scheduled-count">0</span>)</h3>
  </div>
  <div class="card-body">
    <div id="scheduled-container">
      <div class="loading-state">⏳ Loading...</div>
    </div>
  </div>
</div>

<div id="generateModal" class="modal-overlay" style="display:none">
  <div class="modal-content" style="max-width:900px">
    <div class="modal-header">
      <h3>🎨 Generate Konten</h3>
      <button class="btn btn-ghost" onclick="closeGenerateModal()">✕</button>
    </div>
    <div class="modal-body">
      <div id="generate-form" class="form-stack">
        <div class="form-group">
          <label>Produk: <strong id="modal-product-name"></strong></label>
        </div>
        <div class="form-group">
          <label>Jumlah Komentar: <span id="comment-count-display">3</span></label>
          <input type="range" id="comment-count" min="2" max="5" value="3" oninput="document.getElementById('comment-count-display').textContent=this.value">
        </div>
        <button class="btn btn-primary btn-glow" onclick="generateVariations()">🤖 Generate Konten</button>
      </div>
      
      <div id="generate-progress" style="display:none">
        <div class="progress-container">
          <div class="progress-bar">
            <div class="progress-fill" id="progress-fill"></div>
          </div>
          <p id="progress-text">Memproses...</p>
        </div>
      </div>
      
      <div id="variations-result" style="display:none">
        <h4 style="margin:20px 0 16px">✨ Konten Siap Pakai</h4>
        <div class="variations-grid" id="variations-grid"></div>
        <div style="margin-top:20px;display:flex;gap:12px;justify-content:flex-end">
          <button class="btn btn-outline" onclick="closeGenerateModal()">Batal</button>
          <button class="btn btn-success" onclick="scheduleVariations()">📅 Jadwalkan ke Queue</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.product-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}
.stat-card-product {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius);
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  transition: var(--transition);
}
.stat-card-product:hover {
  border-color: var(--border-glow);
  transform: translateY(-2px);
}
.product-grid {
  display: grid;
  grid-template-columns: 400px 1fr;
  gap: 20px;
}
.products-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.product-item {
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 16px;
  display: block !important;
  transition: var(--transition);
}
.product-item:hover {
  border-color: var(--border-glow);
}
.product-info {
  flex: 1;
}
.product-name {
  font-weight: 600;
  font-size: 15px;
  margin-bottom: 4px;
  color: var(--text-primary);
}
.product-desc {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}
.product-link {
  font-size: 12px;
  color: var(--accent-primary);
  text-decoration: none;
}
.product-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}
.loading-state, .empty-state-product {
  text-align: center;
  padding: 40px 20px;
  color: var(--text-secondary);
}
.progress-container {
  text-align: center;
  padding: 40px 20px;
}
.progress-bar {
  width: 100%;
  height: 8px;
  background: var(--bg-tertiary);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 16px;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-primary), var(--accent-success));
  transition: width 0.3s ease;
  width: 0%;
}
.variations-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px;
}
.variation-card {
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 16px;
  transition: var(--transition);
}
.variation-card:hover {
  border-color: var(--accent-primary);
}
.variation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.angle-badge {
  background: var(--accent-primary);
  color: white;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
}
.variation-preview {
  font-size: 13px;
  color: var(--text-secondary);
}
.variation-preview strong {
  color: var(--text-primary);
  display: block;
  margin: 8px 0 4px;
}

.variations-container {
  margin-top: 15px;
  padding: 16px;
  background: var(--bg-card);
  border-radius: 12px;
  border: 1px solid rgba(124, 106, 255, 0.1);
}

.variations-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(124, 106, 255, 0.15);
}

.variations-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 8px;
}

.variations-count {
  background: rgba(124, 106, 255, 0.15);
  padding: 3px 10px;
  border-radius: 8px;
  font-size: 12px;
  color: var(--accent-primary);
  font-weight: 600;
}

.variation-item {
  margin: 10px 0;
  padding: 14px;
  background: var(--bg-secondary);
  border-radius: 10px;
  border: 1px solid rgba(124, 106, 255, 0.1);
  transition: var(--transition);
}

.variation-item:hover {
  background: var(--bg-card-hover);
  border-color: rgba(124, 106, 255, 0.3);
  transform: translateY(-2px);
}

.variation-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.variation-content {
  flex: 1;
  min-width: 0;
}

.angle-badge {
  display: inline-block;
  font-size: 11px;
  padding: 4px 10px;
  background: rgba(124, 106, 255, 0.2);
  color: var(--accent-primary);
  border-radius: 6px;
  font-weight: 600;
  margin-bottom: 8px;
  border: 1px solid rgba(124, 106, 255, 0.3);
}

.variation-text {
  margin: 8px 0 0 0;
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.variation-status {
  font-size: 16px;
  margin-left: 6px;
}

.btn-schedule {
  padding: 8px 16px;
  background: var(--accent-primary);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  white-space: nowrap;
}

.btn-schedule:hover:not(:disabled) {
  background: #9580ff;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px var(--accent-primary-glow);
}

.btn-schedule:disabled {
  background: var(--bg-tertiary);
  color: var(--text-muted);
  cursor: not-allowed;
  opacity: 0.5;
}

.btn-view {
  padding: 8px 16px;
  background: var(--bg-tertiary);
  color: var(--text-primary);
  border: 1px solid rgba(124, 106, 255, 0.2);
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  white-space: nowrap;
}

.btn-view:hover {
  background: var(--bg-card-hover);
  border-color: var(--accent-primary);
  transform: translateY(-2px);
}

.btn-secondary {
  padding: 8px 16px;
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
}

.btn-secondary:hover {
  background: var(--bg-card-hover);
  color: var(--text-primary);
  border-color: var(--border-glow);
}

.modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  align-items: center;
  justify-content: center;
}

.modal.show {
  display: flex;
}

@media (max-width: 1024px) {
  .product-grid {
    grid-template-columns: 1fr;
  }
  
  .variation-header-row {
    flex-direction: column;
    gap: 10px;
  }
  
  .btn-schedule {
    width: 100%;
  }
}
</style>

<script>
let appData = { products: [], accounts: [], stats: {} };
let currentProductId = null;
let generatedVariations = null;

// Load data on page load
document.addEventListener('DOMContentLoaded', loadData);

async function loadData() {
  try {
    const response = await fetch('/product/api/data?v=' + Date.now());
    const data = await response.json();
    
    if (data.success) {
      appData = data;
      renderStats(data.stats);
      renderProducts(data.products);
      renderScheduledPosts(data.scheduledPosts || []);
    }
  } catch (error) {
    console.error('Error loading data:', error);
    document.getElementById('products-container').innerHTML = 
      '<div class="empty-state-product">❌ Error loading products</div>';
  }
}

function renderStats(stats) {
  document.getElementById('stat-products').textContent = stats.totalProducts;
  document.getElementById('stat-variations').textContent = stats.totalVariations;
  document.getElementById('stat-accounts').textContent = stats.activeAccounts;
}

function renderScheduledPosts(posts) {
  console.log('renderScheduledPosts called with:', posts);
  const container = document.getElementById('scheduled-container');
  document.getElementById('scheduled-count').textContent = posts.length;
  
  if (posts.length === 0) {
    container.innerHTML = '<div class="empty-state-product"><div style="font-size:48px;margin-bottom:16px">📅</div><div style="font-weight:600;margin-bottom:8px">Belum Ada Konten Terjadwal</div><div>Jadwalkan konten promosi untuk posting otomatis</div></div>';
    return;
  }
  
  let html = '<div style="display:flex;flex-direction:column;gap:12px">';
  
  posts.forEach(post => {
    const scheduledDate = new Date(post.scheduled_at);
    const dateStr = scheduledDate.toLocaleString('id-ID', { 
      day: '2-digit', 
      month: 'short', 
      year: 'numeric',
      hour: '2-digit', 
      minute: '2-digit' 
    });
    
    // Gunakan content_main jika topic kosong/null
    const displayText = (post.topic && post.topic.trim()) ? post.topic : (post.content_main || '').substring(0, 100);
    const needsEllipsis = !post.topic && displayText.length >= 100;
    
    html += '<div style="background:var(--bg-secondary);padding:14px;border-radius:10px;border:1px solid rgba(124,106,255,0.1)">' +
      '<div style="display:flex;justify-content:space-between;align-items:start;gap:12px">' +
        '<div style="flex:1">' +
          '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">' +
            '<span style="font-size:12px;padding:3px 8px;background:rgba(124,106,255,0.2);color:var(--accent-primary);border-radius:6px;font-weight:600">@' + escapeHtml(post.username || 'Unknown') + '</span>' +
          '</div>' +
          '<p style="margin:0;font-size:13px;color:var(--text-secondary);line-height:1.5">' + escapeHtml(displayText) + (needsEllipsis ? '...' : '') + '</p>' +
          '<div style="margin-top:8px;font-size:12px;color:var(--text-muted)">🕐 ' + dateStr + '</div>' +
        '</div>' +
        '<button class="btn btn-sm btn-danger" onclick="cancelSchedule(' + post.id + ')">❌</button>' +
      '</div>' +
    '</div>';
  });
  
  html += '</div>';
  container.innerHTML = html;
}

function cancelSchedule(postId) {
  if (!confirm('Batalkan jadwal posting ini?')) return;
  
  fetch('/product/cancel-schedule/' + postId, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        alert('✅ Jadwal dibatalkan');
        loadData();
      } else {
        alert('❌ Error: ' + data.error);
      }
    })
    .catch(err => alert('❌ Error: ' + err.message));
}

function renderProducts(products) {
  const container = document.getElementById('products-container');
  document.getElementById('product-count').textContent = products.length;
  
  if (products.length === 0) {
    container.innerHTML = '<div class="empty-state-product"><div style="font-size:48px;margin-bottom:16px">🛍️</div><div style="font-weight:600;margin-bottom:8px">Belum Ada Produk</div><div>Tambahkan produk untuk mulai generate konten promosi</div></div>';
    return;
  }
  
  // Render products dengan variations
  let html = '<div class="products-list">';
  
  for (const product of products) {
    html += '<div class="product-item">' +
      '<div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:12px;border-bottom:1px solid rgba(124,106,255,0.15);cursor:pointer" onclick="toggleProduct(' + product.id + ')">' +
        '<div style="display:flex;align-items:center;gap:10px">' +
          '<span id="arrow-' + product.id + '" style="transition:transform 0.3s">▶</span>' +
          '<div class="product-name" style="font-size:18px;font-weight:700;color:var(--text-primary);margin:0">' + escapeHtml(product.product_name) + '</div>' +
        '</div>' +
        '<div style="display:flex;gap:10px;align-items:center" onclick="event.stopPropagation()">' +
          '<a href="' + escapeHtml(product.affiliate_link) + '" target="_blank" class="product-link">🔗 Link</a>' +
          '<button class="btn btn-sm btn-warning" onclick="editProduct(' + product.id + ')">✏️ Edit</button>' +
          '<button class="btn btn-sm btn-primary" onclick="openGenerateModal(' + product.id + ', \\'' + escapeHtml(product.product_name).replace(/'/g, "\\\\'") + '\\')">🎨 Generate</button>' +
          '<button class="btn btn-sm btn-danger" onclick="deleteProduct(' + product.id + ')">🗑️</button>' +
        '</div>' +
      '</div>' +
      '<div id="content-' + product.id + '" style="display:none;margin-top:15px">' +
        '<div id="variations-' + product.id + '"></div>' +
      '</div>' +
    '</div>';
  }
  
  container.innerHTML = html + '</div>';
  
  // Load variations untuk setiap produk
  products.forEach(async (product) => {
    const varResponse = await fetch('/product/variations/' + product.id);
    const varData = await varResponse.json();
    const variations = varData.variations || [];
    
    // Store variations
    variations.forEach(v => {
      allVariations[v.id] = v;
    });
    
    if (variations.length > 0) {
      let varHtml = '<div class="variations-container">' +
        '<div class="variations-header">' +
          '<div class="variations-title">' +
            '<span>📝 Variasi Konten</span>' +
            '<span class="variations-count">' + variations.length + '</span>' +
          '</div>' +
        '</div>';
      
      variations.forEach(v => {
        const scheduled = v.is_scheduled ? '<span class="variation-status">✅</span>' : '';
        const btnDisabled = v.is_scheduled ? 'disabled' : '';
        const btnText = v.is_scheduled ? '✅ Terjadwal' : '📅 Jadwalkan';
        
        varHtml += '<div class="variation-item">' +
          '<div class="variation-header-row">' +
            '<div class="variation-content">' +
              '<div>' +
                '<span class="angle-badge">' + escapeHtml(v.angle || 'Variation') + '</span>' + scheduled +
              '</div>' +
              '<p class="variation-text">' + escapeHtml((v.content_main || '').substring(0, 120)) + '...</p>' +
            '</div>' +
            '<div style="display:flex;flex-direction:column;gap:8px">' +
              '<button class="btn-schedule" onclick="scheduleVariation(' + v.id + ')" ' + btnDisabled + '>' + btnText + '</button>' +
              '<button class="btn-view" onclick="viewVariation(' + v.id + ')">👁️ Lihat</button>' +
            '</div>' +
          '</div>' +
        '</div>';
      });
      
      varHtml += '</div>';
      document.getElementById('variations-' + product.id).innerHTML = varHtml;
    }
  });
}

function renderAccountOptions(accounts) {
  const select = document.getElementById('target-account');
  select.innerHTML = '<option value="">— Pilih Akun —</option>' + 
    accounts.map(acc => '<option value="' + acc.id + '">@' + escapeHtml(acc.username) + '</option>').join('');
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function deleteProduct(id) {
  if (!confirm('Hapus produk ini?')) return;
  
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/product/product/delete/' + id;
  document.body.appendChild(form);
  form.submit();
}

function openGenerateModal(productId, productName) {
  currentProductId = productId;
  document.getElementById('modal-product-name').textContent = productName;
  document.getElementById('generate-form').style.display = 'block';
  document.getElementById('generate-progress').style.display = 'none';
  document.getElementById('variations-result').style.display = 'none';
  document.getElementById('generateModal').style.display = 'flex';
}

function closeGenerateModal() {
  document.getElementById('generateModal').style.display = 'none';
  currentProductId = null;
  generatedVariations = null;
}

async function generateVariations() {
  const commentCount = document.getElementById('comment-count').value;
  
  document.getElementById('generate-form').style.display = 'none';
  document.getElementById('generate-progress').style.display = 'block';
  
  const progressFill = document.getElementById('progress-fill');
  const progressText = document.getElementById('progress-text');
  
  try {
    // Animate progress bar
    let progress = 0;
    const progressInterval = setInterval(() => {
      progress += 2;
      if (progress <= 90) {
        progressFill.style.width = progress + '%';
      }
    }, 500);
    
    progressText.textContent = '🤖 Sedang generate konten... (tunggu 10-20 detik)';
    
    const response = await fetch('/product/generate-variations', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        product_id: currentProductId,
        comment_count: commentCount,
        variation_count: 1
      })
    });
    
    clearInterval(progressInterval);
    progressFill.style.width = '100%';
    
    const data = await response.json();
    
    if (!data.success) {
      alert('❌ Error: ' + data.error);
      closeGenerateModal();
      return;
    }
    
    // Auto-save variations
    const saveResponse = await fetch('/product/save-variations', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        product_id: currentProductId,
        variations: JSON.stringify(data.variations)
      })
    });
    
    const saveData = await saveResponse.json();
    
    if (saveData.success) {
      alert('✅ Konten berhasil disimpan!');
      closeGenerateModal();
      loadData();
    } else {
      alert('❌ Error: ' + saveData.error);
      closeGenerateModal();
    }
    
  } catch (error) {
    alert('❌ Error: ' + error.message);
    closeGenerateModal();
  }
}

function displayVariations(variations) {
  const grid = document.getElementById('variations-grid');
  grid.innerHTML = variations.map((v, i) => 
    '<div class="variation-card">' +
      '<div class="variation-header">' +
        '<span class="angle-badge">' + escapeHtml(v.angle || 'Variation') + '</span>' +
        '<input type="checkbox" checked data-index="' + i + '">' +
      '</div>' +
      '<div class="variation-preview">' +
        '<strong>Main Post:</strong>' +
        '<p>' + escapeHtml((v.content_main || '').substring(0, 150)) + '...</p>' +
        '<strong>Comments (' + (v.content_comments?.length || 0) + '):</strong>' +
        '<p>' + escapeHtml((v.content_comments?.[0] || 'No comment').substring(0, 100)) + '...</p>' +
      '</div>' +
    '</div>'
  ).join('');
  
  document.getElementById('generate-progress').style.display = 'none';
  document.getElementById('variations-result').style.display = 'block';
}

async function scheduleVariations() {
  const checkboxes = document.querySelectorAll('#variations-grid input[type="checkbox"]:checked');
  
  if (checkboxes.length === 0) {
    alert('❌ Pilih minimal 1 variasi');
    return;
  }
  
  const selectedVariations = Array.from(checkboxes).map(cb => {
    const index = parseInt(cb.getAttribute('data-index'));
    return generatedVariations[index];
  });
  
  try {
    const response = await fetch('/product/save-variations', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        product_id: currentProductId,
        variations: JSON.stringify(selectedVariations)
      })
    });
    
    const data = await response.json();
    
    if (data.success) {
      alert('✅ ' + data.savedCount + ' variasi berhasil disimpan!');
      closeGenerateModal();
      loadData(); // Reload data
    } else {
      alert('❌ Error: ' + data.error);
    }
  } catch (error) {
    alert('❌ Error: ' + error.message);
  }
}

document.getElementById('generateModal').onclick = (e) => {
  if (e.target.id === 'generateModal') closeGenerateModal();
};

let currentVariationId = null;
let allVariations = {}; // Store all variations by id
let currentEditProductId = null;

function toggleProduct(productId) {
  const content = document.getElementById('content-' + productId);
  const arrow = document.getElementById('arrow-' + productId);
  
  if (content.style.display === 'none') {
    content.style.display = 'block';
    arrow.style.transform = 'rotate(90deg)';
  } else {
    content.style.display = 'none';
    arrow.style.transform = 'rotate(0deg)';
  }
}

function editProduct(productId) {
  const product = appData.products.find(p => p.id === productId);
  if (!product) return;
  
  currentEditProductId = productId;
  document.getElementById('edit-product-name').value = product.product_name;
  document.getElementById('edit-description').value = product.description || '';
  document.getElementById('edit-affiliate-link').value = product.affiliate_link;
  document.getElementById('edit-modal').style.display = 'flex';
}

function closeEditModal() {
  document.getElementById('edit-modal').style.display = 'none';
  currentEditProductId = null;
}

async function saveProduct() {
  const name = document.getElementById('edit-product-name').value;
  const description = document.getElementById('edit-description').value;
  const link = document.getElementById('edit-affiliate-link').value;
  
  if (!name || !link) {
    alert('❌ Nama produk dan link wajib diisi');
    return;
  }
  
  try {
    const response = await fetch('/product/product/update/' + currentEditProductId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        product_name: name,
        description: description,
        affiliate_link: link
      })
    });
    
    const data = await response.json();
    
    if (data.success) {
      alert('✅ Produk berhasil diupdate!');
      closeEditModal();
      loadData();
    } else {
      alert('❌ Error: ' + data.error);
    }
  } catch (error) {
    alert('❌ Error: ' + error.message);
  }
}

function scheduleVariation(variationId) {
  currentVariationId = variationId;
  
  // Populate accounts
  const select = document.getElementById('schedule-account');
  select.innerHTML = '<option value="">— Pilih Akun —</option>' + 
    appData.accounts.map(acc => '<option value="' + acc.id + '">@' + escapeHtml(acc.username) + '</option>').join('');
  
  // Set default time (now + 1 hour)
  const now = new Date();
  now.setHours(now.getHours() + 1);
  document.getElementById('schedule-time').value = now.toISOString().slice(0, 16);
  
  document.getElementById('schedule-modal').style.display = 'flex';
}

function closeScheduleModal() {
  document.getElementById('schedule-modal').style.display = 'none';
  currentVariationId = null;
}

async function confirmSchedule() {
  const accountId = document.getElementById('schedule-account').value;
  const scheduledTime = document.getElementById('schedule-time').value;
  
  if (!accountId) {
    alert('❌ Pilih akun terlebih dahulu');
    return;
  }
  
  if (!scheduledTime) {
    alert('❌ Pilih waktu posting');
    return;
  }
  
  try {
    const response = await fetch('/product/schedule-variation', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        variation_id: currentVariationId,
        account_id: accountId,
        scheduled_time: scheduledTime
      })
    });
    
    const data = await response.json();
    
    if (data.success) {
      alert('✅ Variasi berhasil dijadwalkan!');
      closeScheduleModal();
      loadData();
    } else {
      alert('❌ Error: ' + data.error);
    }
  } catch (error) {
    alert('❌ Error: ' + error.message);
  }
}

function viewVariation(variationId) {
  const variation = allVariations[variationId];
  if (!variation) return;
  
  const comments = JSON.parse(variation.content_comments || '[]');
  
  let html = '<div style="max-height:500px;overflow-y:auto">';
  html += '<div style="margin-bottom:20px">';
  html += '<h4 style="color:var(--accent-primary);margin-bottom:10px">📝 Main Post</h4>';
  html += '<div style="background:var(--bg-secondary);padding:15px;border-radius:8px;white-space:pre-wrap;line-height:1.6">' + escapeHtml(variation.content_main) + '</div>';
  html += '</div>';
  
  if (comments.length > 0) {
    html += '<div>';
    html += '<h4 style="color:var(--accent-primary);margin-bottom:10px">💬 Comments (' + comments.length + ')</h4>';
    comments.forEach((comment, i) => {
      html += '<div style="background:var(--bg-secondary);padding:12px;border-radius:8px;margin-bottom:10px;border-left:3px solid var(--accent-primary)">';
      html += '<strong style="color:var(--text-secondary);font-size:12px">Comment ' + (i+1) + '</strong>';
      html += '<p style="margin:8px 0 0 0;white-space:pre-wrap;line-height:1.6">' + escapeHtml(comment) + '</p>';
      html += '</div>';
    });
    html += '</div>';
  }
  html += '</div>';
  
  document.getElementById('view-content').innerHTML = html;
  document.getElementById('view-modal').style.display = 'flex';
}

function closeViewModal() {
  document.getElementById('view-modal').style.display = 'none';
}

</script>
` }) %>


