{{#> layouts/main page="register" hideNavbar=true}}

<div class="auth-form">
  <div class="auth-header">
    <h1>🤖 ThreadsBot</h1>
    <p>SaaS Platform - Daftar Akun Baru</p>
  </div>
  
  <form action="/register" method="POST" class="form">
    <div class="form-group">
      <label for="name">Nama Lengkap</label>
      <input type="text" id="name" name="name" required>
    </div>
    
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required>
    </div>
    
    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required minlength="6">
    </div>
    
    <div class="form-group">
      <label for="confirm_password">Konfirmasi Password</label>
      <input type="password" id="confirm_password" name="confirm_password" required>
    </div>
    
    <div class="plan-selection">
      <h4>Plan Starter (Gratis)</h4>
      <div class="plan-info">
        <ul class="plan-features">
          <li>3 akun Threads</li>
          <li>500 posts per bulan</li>
          <li>AI content generation</li>
          <li>Basic support</li>
        </ul>
      </div>
    </div>
    
    <button type="submit" class="btn btn-primary btn-full">Daftar Sekarang</button>
  </form>
  
  <div class="auth-footer">
    <p>Sudah punya akun? <a href="/login">Masuk di sini</a></p>
  </div>
</div>

{{/layouts/main}}
