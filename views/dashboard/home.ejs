<div class="dashboard-header">
  <div class="welcome-section">
    <h1>👋 Selamat datang, <%= user.name %>!</h1>
    <div class="plan-badge">
      🚀 <%= user.plan.toUpperCase() %> PLAN
    </div>
  </div>
  
  <div class="trial-info">
    <div class="trial-badge">
      ⏰ Trial aktif
    </div>
  </div>
</div>

<!-- Usage Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon">👥</div>
    <div class="stat-content">
      <div class="stat-number"><%= stats.total_accounts %>/<%= stats.accounts_limit %></div>
      <div class="stat-label">Akun Threads</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon">📝</div>
    <div class="stat-content">
      <div class="stat-number"><%= stats.posts_this_month %>/<%= stats.posts_limit %></div>
      <div class="stat-label">Posts Bulan Ini</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon">✅</div>
    <div class="stat-content">
      <div class="stat-number"><%= stats.connected_accounts %></div>
      <div class="stat-label">Akun Terhubung</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon">⚠️</div>
    <div class="stat-content">
      <div class="stat-number"><%= stats.expired_accounts %></div>
      <div class="stat-label">Token Expired</div>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
  <h2>🚀 Quick Actions</h2>
  <div class="action-grid">
    <a href="/accounts" class="action-card">
      <div class="action-icon">👥</div>
      <div class="action-title">Kelola Akun</div>
      <div class="action-desc">Tambah & kelola akun Threads</div>
    </a>
    
    <a href="/posts/create" class="action-card">
      <div class="action-icon">✍️</div>
      <div class="action-title">Buat Post</div>
      <div class="action-desc">Buat konten dengan AI</div>
    </a>
    
    <a href="/queue" class="action-card">
      <div class="action-icon">⏰</div>
      <div class="action-title">Content Queue</div>
      <div class="action-desc">Jadwalkan posting otomatis</div>
    </a>
    
    <a href="/affiliate" class="action-card">
      <div class="action-icon">💰</div>
      <div class="action-title">Affiliate</div>
      <div class="action-desc">Kelola produk affiliate</div>
    </a>
  </div>
</div>

<!-- Empty State -->
<div class="empty-state">
  <div class="empty-icon">📝</div>
  <div class="empty-title">Belum Ada Aktivitas</div>
  <div class="empty-desc">Mulai dengan menambahkan akun Threads dan buat post pertama Anda</div>
  <a href="/accounts" class="btn btn-primary">Tambah Akun</a>
</div>

