<%- include('layout', { body: `
<div class="queue-stats-dashboard">
  <div class="stat-card-queue">
    <div class="stat-icon">📦</div>
    <div class="stat-info">
      <div class="stat-value">${globalStats.totalQueued}</div>
      <div class="stat-label">Total Antrian</div>
    </div>
  </div>
  <div class="stat-card-queue stat-success">
    <div class="stat-icon">✅</div>
    <div class="stat-info">
      <div class="stat-value">${globalStats.totalUsed}</div>
      <div class="stat-label">Terpakai</div>
    </div>
  </div>
  <div class="stat-card-queue stat-info">
    <div class="stat-icon">👥</div>
    <div class="stat-info">
      <div class="stat-value">${globalStats.activeQueues}/${globalStats.totalAccounts}</div>
      <div class="stat-label">Akun Aktif</div>
    </div>
  </div>
</div>

<div class="queue-tabs">
  <button class="queue-tab active" onclick="switchTab('generate')">🤖 Generate</button>
  <button class="queue-tab" onclick="switchTab('list')">📋 Antrian (${globalStats.totalQueued})</button>
  <button class="queue-tab" onclick="switchTab('settings')">⚙️ Pengaturan</button>
</div>

<div id="tab-generate" class="tab-content active">
  <div class="card">
    <div class="card-header">
      <h3>🤖 Generate Konten Otomatis</h3>
    </div>
    <div class="card-body">
      ${accounts.length === 0 ? '<div class="empty-state-enhanced"><div class="empty-icon">👥</div><div class="empty-title">Belum Ada Akun</div><div class="empty-desc">Tambahkan akun Threads terlebih dahulu</div><a href="/accounts" class="btn btn-primary" style="margin-top:16px">+ Tambah Akun</a></div>' : ''}
      ${accounts.length > 0 ? 
        '<div class="form-group" style="margin-bottom:20px">' +
          '<label>Pilih Akun Threads</label>' +
          '<select id="gen-account-select" class="form-select" onchange="updateGenerateForm(this.value)">' +
            '<option value="">— Pilih Akun —</option>' +
            accounts.map(acc => '<option value="' + acc.id + '">@' + acc.username + ' (' + (queueStats[acc.id]?.queued || 0) + ' antrian)</option>').join('') +
          '</select>' +
        '</div>' +
        '<div id="generate-form-container" style="display:none">' +
          '<div class="account-info-box" id="account-info" style="margin-bottom:20px"></div>' +
          '<form id="generate-form" method="POST" class="form-stack">' +
            '<div class="form-row" style="gap:16px;margin-bottom:20px">' +
              '<div class="form-group" style="flex:1">' +
                '<label>💬 Jumlah Komentar</label>' +
                '<select name="comment_count" class="form-select">' +
                  '<option value="2">2 komentar</option>' +
                  '<option value="3" selected>3 komentar</option>' +
                  '<option value="4">4 komentar</option>' +
                  '<option value="5">5 komentar</option>' +
                '</select>' +
              '</div>' +
              '<div class="form-group" style="flex:1">' +
                '<label>📦 Jumlah Konten</label>' +
                '<select name="count" class="form-select">' +
                  '<option value="3">3 konten</option>' +
                  '<option value="5">5 konten</option>' +
                  '<option value="10" selected>10 konten</option>' +
                '</select>' +
              '</div>' +
            '</div>' +
            '<div class="form-actions">' +
              '<button type="submit" class="btn btn-primary btn-glow">🤖 Generate Sekarang</button>' +
            '</div>' +
          '</form>' +
        '</div>' : ''}
    </div>
  </div>
</div>

<div id="tab-list" class="tab-content">
  <div class="card">
    <div class="card-header">
      <h3>📋 Daftar Antrian (${globalStats.totalQueued} total)</h3>
      <div class="queue-controls">
        <input type="text" id="searchQueue" placeholder="🔍 Cari topik..." class="search-input">
        <select id="filterAccount" class="form-select" style="width:200px">
          <option value="all">Semua Akun</option>
          ${accounts.map(acc => '<option value="' + acc.id + '">@' + acc.username + ' (' + (queueStats[acc.id]?.queued || 0) + ')</option>').join('')}
        </select>
        <select id="sortQueue" class="form-select" style="width:150px">
          <option value="newest">Terbaru</option>
          <option value="oldest">Terlama</option>
          <option value="topic">Topik A-Z</option>
        </select>
      </div>
    </div>
    <div class="card-body">
      ${queueItems.length === 0 ? '<div class="empty-state-enhanced"><div class="empty-icon">📝</div><div class="empty-title">Antrian Kosong</div><div class="empty-desc">Generate konten untuk mengisi antrian</div></div>' : ''}
      ${queueItems.length > 0 ? 
        '<div class="bulk-actions-bar">' +
          '<input type="checkbox" id="select-all-queue" onchange="toggleSelectAllQueue(this)">' +
          '<span id="selected-count">0 dipilih</span>' +
          '<div class="bulk-buttons">' +
            '<button class="btn btn-sm btn-success" onclick="bulkPostQueue()" id="bulk-post-btn" disabled>📤 Post Terpilih</button>' +
            '<button class="btn btn-sm btn-danger" onclick="bulkDeleteQueue()" id="bulk-delete-btn" disabled>🗑️ Hapus Terpilih</button>' +
          '</div>' +
        '</div>' : ''}
      <div class="queue-items-grid" id="queueItemsGrid">
        ${queueItems.filter(q => q.status === 'queued').map((item, index) =>
          '<div class="queue-item-card" data-id="' + item.id + '" data-account="' + item.account_id + '" data-topic="' + (item.topic || '').toLowerCase() + '" data-date="' + item.created_at + '">' +
            '<div class="queue-item-header">' +
              '<input type="checkbox" class="queue-item-checkbox" value="' + item.id + '" onchange="updateBulkButtons()">' +
              '<span class="queue-badge">#' + (index + 1) + '</span>' +
              '<span class="queue-username">@' + item.username + '</span>' +
            '</div>' +
            '<div class="queue-item-topic">' + item.topic + '</div>' +
            '<div class="queue-item-preview">' + (item.content_main || '').substring(0, 150) + '...</div>' +
            '<div class="queue-item-footer">' +
              '<span class="queue-meta">💬 ' + item.comment_count + '</span>' +
              '<span class="queue-meta">🕐 ' + new Date(item.created_at).toLocaleDateString('id-ID', {day: 'numeric', month: 'short'}) + '</span>' +
            '</div>' +
            '<div class="queue-item-actions">' +
              '<button class="btn btn-sm btn-ghost" onclick="previewQueue(' + item.id + ')">👁️</button>' +
              '<button class="btn btn-sm btn-ghost" onclick="editQueue(' + item.id + ')">✏️</button>' +
              '<button class="btn btn-sm btn-success" onclick="postQueueNow(' + item.id + ', ' + item.account_id + ')">📤</button>' +
              '<button class="btn btn-sm btn-danger" onclick="deleteQueue(' + item.id + ')">🗑️</button>' +
            '</div>' +
          '</div>'
        ).join('')}
      </div>
    </div>
  </div>
</div>

<div id="tab-settings" class="tab-content">
  <div class="card">
    <div class="card-header">
      <h3>⚙️ Pengaturan Jadwal Auto Post</h3>
    </div>
    <div class="card-body">
      ${accounts.map(acc => 
        '<div class="settings-account-card-compact">' +
          '<div class="settings-compact-header">' +
            '<div class="settings-compact-user">' +
              '<span class="settings-compact-avatar">👤</span>' +
              '<div>' +
                '<div class="settings-compact-username">@' + acc.username + '</div>' +
                '<div class="settings-compact-meta">' + (acc.theme || 'Tema belum diatur') + ' • ' + (queueStats[acc.id]?.queued || 0) + ' antrian • ' + nextPostingTimes[acc.id] + '</div>' +
              '</div>' +
            '</div>' +
            '<span class="settings-compact-status ' + (queueConfigs[acc.id]?.is_enabled ? 'status-active' : 'status-inactive') + '">' + (queueConfigs[acc.id]?.is_enabled ? '● Aktif' : '○ Nonaktif') + '</span>' +
          '</div>' +
          '<form action="/queue/settings/' + acc.id + '" method="POST" class="settings-compact-form">' +
            '<div class="settings-compact-controls">' +
              '<label class="toggle-switch-compact">' +
