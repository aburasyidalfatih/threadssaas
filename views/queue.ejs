<script>
const accountsData = ${JSON.stringify(accounts.map(a => ({id: a.id, username: a.username, theme: a.theme, queued: queueStats[a.id]?.queued || 0, lastGen: queueStats[a.id]?.lastGenerated})))};

function switchTab(tab) {
  document.querySelectorAll('.queue-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  
  event.target.classList.add('active');
  document.getElementById('tab-' + tab).classList.add('active');
}

function updateGenerateForm(accountId) {
  const container = document.getElementById('generate-form-container');
  const infoBox = document.getElementById('account-info');
  const form = document.getElementById('generate-form');
  
  if (!accountId) {
    container.style.display = 'none';
    return;
  }
  
  const account = accountsData.find(a => a.id == accountId);
  if (!account) return;
  
  infoBox.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:center"><div><strong>@' + account.username + '</strong><br><small>' + (account.theme || 'Tema belum diatur') + '</small></div><div><span style="color:var(--accent-primary);font-weight:600">' + account.queued + '</span> antrian tersedia</div></div>';
  
  form.action = '/queue/generate/' + accountId;
  container.style.display = 'block';
}

function toggleSelectAllQueue(checkbox) {
  document.querySelectorAll('.queue-item-checkbox').forEach(cb => {
    if (cb.closest('.queue-item-card').style.display !== 'none') {
      cb.checked = checkbox.checked;
    }
  });
  updateBulkButtons();
}

function updateBulkButtons() {
  const checked = document.querySelectorAll('.queue-item-checkbox:checked').length;
  document.getElementById('selected-count').textContent = checked + ' dipilih';
  document.getElementById('bulk-post-btn').disabled = checked === 0;
  document.getElementById('bulk-delete-btn').disabled = checked === 0;
}

function bulkPostQueue() {
  const ids = Array.from(document.querySelectorAll('.queue-item-checkbox:checked')).map(cb => cb.value);
  if (ids.length === 0) return;
  
  if (!confirm('Post ' + ids.length + ' konten sekarang?')) return;
  
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/queue/bulk-post';
  ids.forEach(id => {
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'ids[]';
    input.value = id;
    form.appendChild(input);
  });
  document.body.appendChild(form);
  form.submit();
}

function bulkDeleteQueue() {
  const ids = Array.from(document.querySelectorAll('.queue-item-checkbox:checked')).map(cb => cb.value);
  if (ids.length === 0) return;
  
  if (!confirm('Hapus ' + ids.length + ' item dari antrian?')) return;
  
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/queue/delete-multiple';
  ids.forEach(id => {
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'ids[]';
    input.value = id;
    form.appendChild(input);
  });
  document.body.appendChild(form);
  form.submit();
}

// Search and filter
document.addEventListener('DOMContentLoaded', () => {
  const searchInput = document.getElementById('searchQueue');
  const filterAccount = document.getElementById('filterAccount');
  const sortQueue = document.getElementById('sortQueue');
  
  if (searchInput && filterAccount && sortQueue) {
    function filterAndSort() {
      const searchTerm = searchInput.value.toLowerCase();
      const accountFilter = filterAccount.value;
      const sortBy = sortQueue.value;
      
      const grid = document.getElementById('queueItemsGrid');
      const items = Array.from(grid.querySelectorAll('.queue-item-card'));
      
      // Filter items
      let visibleItems = items.filter(item => {
        const topic = item.getAttribute('data-topic');
        const account = item.getAttribute('data-account');
        
        let show = topic.includes(searchTerm);
        if (show && accountFilter !== 'all') {
          show = account === accountFilter;
        }
        
        item.style.display = show ? 'block' : 'none';
        return show;
      });
      
      // Sort visible items
      visibleItems.sort((a, b) => {
        if (sortBy === 'newest') {
          return new Date(b.getAttribute('data-date')) - new Date(a.getAttribute('data-date'));
        } else if (sortBy === 'oldest') {
          return new Date(a.getAttribute('data-date')) - new Date(b.getAttribute('data-date'));
        } else if (sortBy === 'topic') {
          return a.getAttribute('data-topic').localeCompare(b.getAttribute('data-topic'));
        }
        return 0;
      });
      
      // Re-append in sorted order
      visibleItems.forEach(item => grid.appendChild(item));
      
      // Update counter
      const headerCount = document.querySelector('#tab-list .card-header h3');
      if (headerCount) {
        headerCount.innerHTML = '📋 Daftar Antrian (' + visibleItems.length + ' ditampilkan)';
      }
    }
    
    searchInput.addEventListener('input', filterAndSort);
    filterAccount.addEventListener('change', filterAndSort);
    sortQueue.addEventListener('change', filterAndSort);
  }
});

function previewQueue(id) {
  fetch('/queue/api/' + id)
    .then(r => r.json())
    .then(data => {
      if (!data.success) return alert('❌ Item tidak ditemukan');
      
      const item = data.item;
      const modal = document.createElement('div');
      modal.className = 'modal-overlay';
      modal.innerHTML = '<div class="modal-content" style="max-width:600px"><div class="modal-header"><h3>👁️ Preview Konten</h3><button class="btn btn-ghost" onclick="this.closest(\\'.modal-overlay\\').remove()">✕</button></div><div class="modal-body"><div class="form-group"><label>Topik</label><div style="font-weight:600;padding:12px;background:var(--bg-input);border-radius:8px;margin-bottom:16px">' + item.topic + '</div></div><div class="form-group"><label>Postingan Utama</label><div style="background:var(--bg-input);padding:16px;border-radius:8px;white-space:pre-wrap;margin-bottom:16px;line-height:1.5">' + item.content_main + '</div></div><div class="form-group"><label>Komentar Lanjutan (' + item.comments.length + ')</label><div style="background:var(--bg-input);padding:16px;border-radius:8px">' + item.comments.map((c, i) => '<div style="margin-bottom:12px;padding:12px;background:var(--bg-tertiary);border-radius:6px"><strong style="color:var(--accent-primary)">' + (i+1) + '.</strong> ' + c + '</div>').join('') + '</div></div></div></div>';
      modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
      document.body.appendChild(modal);
    })
    .catch(err => alert('❌ Error: ' + err.message));
}

function editQueue(id) {
  fetch('/queue/api/' + id)
    .then(r => r.json())
    .then(data => {
      if (!data.success) return alert('❌ Item tidak ditemukan');
      
      const item = data.item;
      const modal = document.createElement('div');
      modal.className = 'modal-overlay';
      modal.innerHTML = '<div class="modal-content" style="max-width:600px"><div class="modal-header"><h3>✏️ Edit Konten</h3><button class="btn btn-ghost" onclick="this.closest(\\'.modal-overlay\\').remove()">✕</button></div><div class="modal-body"><form action="/queue/edit/' + id + '" method="POST" class="form-stack"><div class="form-group"><label>Topik</label><div style="font-weight:600;padding:12px;background:var(--bg-input);border-radius:8px;margin-bottom:8px">' + item.topic + '</div></div><div class="form-group"><label>Postingan Utama</label><textarea name="content_main" rows="6" style="width:100%;padding:12px;border-radius:8px;background:var(--bg-input);color:var(--text-primary);border:1px solid var(--border-color);font-family:inherit;font-size:14px">' + item.content_main + '</textarea></div><div class="form-group"><label>Komentar Lanjutan (JSON array)</label><textarea name="content_comments" rows="8" style="width:100%;padding:12px;border-radius:8px;background:var(--bg-input);color:var(--text-primary);border:1px solid var(--border-color);font-family:inherit;font-size:13px">' + JSON.stringify(item.comments, null, 2) + '</textarea><small class="form-hint">Format: ["komentar 1", "komentar 2"]</small></div><button type="submit" class="btn btn-primary">💾 Simpan Perubahan</button></form></div></div>';
      modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
      document.body.appendChild(modal);
    })
    .catch(err => alert('❌ Error: ' + err.message));
}

function postQueueNow(queueId, accountId) {
  if (!confirm('📤 Post konten ini sekarang?')) return;
  
  const btn = event.target;
  btn.disabled = true;
  btn.textContent = '⏳';
  
  fetch('/queue/api/' + queueId)
    .then(r => r.json())
    .then(data => {
      if (!data.success) {
        alert('❌ Item tidak ditemukan');
        btn.disabled = false;
        btn.textContent = '📤';
        return;
      }
      
      const item = data.item;
      const comments = item.comments || [];
      
      return fetch('/posts/post-now', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          account_id: accountId,
          topic: item.topic,
          content_main: item.content_main,
          content_comments: comments,
          comment_count: comments.length
        })
      });
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        alert('✅ Posting dimulai!');
        location.reload();
      } else {
        alert('❌ Error: ' + data.error);
        btn.disabled = false;
        btn.textContent = '📤';
      }
    })
    .catch(err => {
      alert('❌ Error: ' + err.message);
      btn.disabled = false;
      btn.textContent = '📤';
    });
}

function deleteQueue(id) {
  if (!confirm('🗑️ Hapus item ini dari antrian?')) return;
  
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/queue/delete/' + id;
  document.body.appendChild(form);
  form.submit();
}
</script>
